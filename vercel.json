{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": {
      "includeFiles": "public/assets/library/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/|avatar/|api/|favicon.ico|robots.txt|sitemap.xml).*)",
      "destination": "/index.html"
    }
  ]
}
